# Database Configuration
DATABASE_URL=postgresql+asyncpg://trading_user:trading_password@localhost:5432/trading_db

# Alpaca API Configuration (Paper Trading)
# Get your keys from: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Application Configuration
DEBUG=True
LOG_LEVEL=INFO

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000"]

# Storage Configuration
MODEL_STORAGE_PATH=/app/storage/models
DATA_CACHE_PATH=/app/storage/data

# Trading Configuration
DEFAULT_COMMISSION=0.0
DEFAULT_SLIPPAGE=0.001
